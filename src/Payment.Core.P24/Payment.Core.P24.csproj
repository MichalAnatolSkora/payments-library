<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- NuGet package metadata -->
    <PackageId>PaymentsLibrary</PackageId>
    <Version>1.0.0</Version>
    <Authors>Michal</Authors>
    <Description>Unified .NET library for integrating with payment providers (Przelewy24, Stripe, PayPal, and more).</Description>
    <PackageTags>payments;przelewy24;stripe;paypal;dotnet</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryType>git</RepositoryType>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Http" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Payment.Models\Payment.Models.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Providers\Models\" />
  </ItemGroup>

</Project>
